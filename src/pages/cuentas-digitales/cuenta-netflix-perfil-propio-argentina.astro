---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Netflix con perfil propio en Argentina 2026 — Tus listas, tu historial";
const description = "Accedé a Netflix con tu propio perfil en Argentina. Tus listas, tu historial, tus recomendaciones. Sin compartir con nadie, con precio en pesos y sin el 51% de impuestos. Activación rápida.";
const url = "https://cuentasdigitales.com.ar/cuentas-digitales/cuenta-netflix-perfil-propio-argentina";

const priceARS = 20000;
const priceCurrency = "ARS";
const PRODUCT_NAME = "Netflix perfil propio Argentina";
const PRODUCT_AMOUNT = 20000;
const PAY_URL = `/pago?item=${encodeURIComponent(PRODUCT_NAME)}&amount=${PRODUCT_AMOUNT}&currency=ARS`;
---

<BaseLayout
  title={title}
  description={description}
  type="product"
  canonical="/cuentas-digitales/cuenta-netflix-perfil-propio-argentina"
  ogImage="/images/netflix-prepago-argentina.jpg"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Product",
      name: "Netflix perfil propio Argentina",
      description,
      brand: { "@type": "Organization", name: "Netflix" },
      url,
      category: "Suscripciones digitales",
      image: ["https://cuentasdigitales.com.ar/images/netflix-prepago-argentina.jpg"],
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "4.8",
        reviewCount: "31",
        bestRating: "5",
        worstRating: "1",
      },
      review: [
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          author: { "@type": "Person", name: "Cecilia T." },
          reviewBody: "Tenía Netflix con mi ex y era un lío. Ahora tengo mi propio perfil, mis propias listas y nadie me mezcla el algoritmo. Mucho mejor.",
          datePublished: "2026-03-18",
        },
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          author: { "@type": "Person", name: "Esteban L." },
          reviewBody: "Quería separar mi perfil del de mi familia. El proceso fue muy claro y rápido.",
          datePublished: "2026-02-05",
        },
      ],
      offers: {
        "@type": "Offer",
        url,
        priceCurrency,
        price: String(priceARS),
        priceValidUntil: "2026-12-31",
        availability: "https://schema.org/InStock",
        itemCondition: "https://schema.org/NewCondition",
        seller: { "@type": "Organization", name: "CuentasDigitales.com.ar" },
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "¿Qué ventaja tiene tener un perfil propio en Netflix?",
          acceptedAnswer: { "@type": "Answer", text: "Con perfil propio tenés tus propias listas, tu historial separado, recomendaciones ajustadas a tu gusto y privacidad total. No compartís con nadie ni te mezclan el contenido que estás siguiendo." },
        },
        {
          "@type": "Question",
          name: "¿Puedo tener mi propio perfil de Netflix sin pagar el plan completo con impuestos?",
          acceptedAnswer: { "@type": "Answer", text: "Sí. A través de CuentasDigitales.com.ar podés acceder a Netflix con perfil propio y precio fijo en pesos, sin el 51% de impuestos que aplica el plan oficial." },
        },
      ],
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: "https://cuentasdigitales.com.ar/" },
        { "@type": "ListItem", position: 2, name: "Cuentas Premium", item: "https://cuentasdigitales.com.ar/cuentas-digitales/" },
        { "@type": "ListItem", position: 3, name: title, item: url },
      ],
    },
  ]}
>
  {/* HERO */}
  <section class="mb-12">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-3xl bg-gradient-to-br from-slate-900 to-violet-900 text-slate-50 shadow-xl overflow-hidden">
        <div class="p-7 md:p-10 space-y-4 max-w-2xl">
          <p class="inline-flex items-center gap-2 text-xs md:text-sm bg-slate-800/70 border border-violet-400/60 rounded-full px-3 py-1 w-fit">
            <span>🎭</span>
            <span>Tu perfil, tus listas · Netflix Argentina 🇦🇷</span>
          </p>
          <h1 class="text-3xl md:text-4xl font-extrabold leading-snug">
            Netflix con tu propio perfil en Argentina
          </h1>
          <div class="rounded-2xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-slate-200/90">
            <p class="font-semibold text-slate-100">👉 Tus listas, tu historial, tus recomendaciones</p>
            <p>Acceso propio, sin compartir con nadie. El algoritmo aprende lo que a vos te gusta, no lo que miran los demás. Precio en pesos sin el 51% de impuestos.</p>
          </div>
          <ul class="text-xs md:text-sm text-slate-200/90 space-y-1 pt-1">
            <li>✅ Perfil 100% tuyo — nadie te mezcla el historial.</li>
            <li>✅ Tus listas de "ver más tarde" siempre organizadas.</li>
            <li>✅ Recomendaciones ajustadas a tu gusto real.</li>
            <li>✅ Precio fijo en pesos, sin impuestos sorpresa.</li>
          </ul>
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a href={PAY_URL} class="inline-flex items-center justify-center rounded-xl bg-violet-600 hover:bg-violet-700 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
              Consultar / Comprar →
            </a>
          </div>
          <p class="text-xs text-slate-400 pt-1">Precio de referencia: <strong>${priceARS.toLocaleString("es-AR")} ARS</strong> (puede variar según disponibilidad).</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto pb-16 space-y-9">

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-4">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>🎯</span>
        <span>¿Por qué importa tener tu propio perfil en Netflix?</span>
      </h2>
      <p class="text-slate-700 text-[15px] leading-relaxed">
        El algoritmo de Netflix aprende de lo que mirás. Si compartís cuenta con alguien, las recomendaciones se mezclan, las listas se confunden y el historial de visualización queda revuelto. Con un perfil propio, Netflix entiende exactamente tu gusto y te sugiere lo que realmente querés ver.
      </p>
      <div class="grid gap-3 md:grid-cols-2 text-sm">
        <div class="rounded-xl bg-violet-50 border border-violet-100 px-4 py-3">
          <p class="font-semibold text-slate-800 mb-2">😤 Perfil compartido con otros</p>
          <ul class="list-disc list-inside space-y-1 text-slate-600">
            <li>Recomendaciones mezcladas con otros gustos.</li>
            <li>"Seguir viendo" lleno de series de otros.</li>
            <li>Sin privacidad en lo que mirás.</li>
            <li>Algoritmo confundido con múltiples perfiles.</li>
          </ul>
        </div>
        <div class="rounded-xl bg-violet-50 border border-violet-100 px-4 py-3">
          <p class="font-semibold text-slate-800 mb-2">✅ Tu propio perfil</p>
          <ul class="list-disc list-inside space-y-1 text-slate-600">
            <li>Recomendaciones 100% ajustadas a vos.</li>
            <li>"Seguir viendo" con lo que realmente querés terminar.</li>
            <li>Historial y listas privadas.</li>
            <li>Algoritmo que te conoce de verdad.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-4">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>🤔</span>
        <span>¿Para quién tiene más sentido tener perfil propio?</span>
      </h2>
      <div class="space-y-2 text-[15px] text-slate-700">
        <div class="flex items-start gap-2">
          <span class="text-violet-500 mt-0.5">✓</span>
          <p>Los que <strong>salieron de una cuenta compartida</strong> y quieren empezar de cero con su propio historial.</p>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-violet-500 mt-0.5">✓</span>
          <p>Los que <strong>vivían con otros</strong> y ahora viven solos — ya no tiene sentido compartir.</p>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-violet-500 mt-0.5">✓</span>
          <p>Los que tienen gustos <strong>muy diferentes</strong> a los demás del hogar y el algoritmo ya no les sirve.</p>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-violet-500 mt-0.5">✓</span>
          <p>Cualquiera que simplemente quiera <strong>su propio espacio</strong> digital sin compartir con nadie.</p>
        </div>
      </div>
    </section>

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-5">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>⚙️</span>
        <span>Cómo funciona el proceso</span>
      </h2>
      <ol class="list-decimal list-inside text-slate-700 text-[15px] leading-relaxed space-y-2">
        <li>Consultás disponibilidad desde el botón de esta página.</li>
        <li>Te confirmamos precio en pesos y medios de pago disponibles.</li>
        <li>Pagás en ARS — transferencia, Mercado Pago u otro medio local.</li>
        <li>Activamos el acceso con tu propio perfil y te guiamos para entrar.</li>
        <li>Empezás de cero: tus listas, tu historial, tu Netflix.</li>
      </ol>
    </section>

    <section class="rounded-3xl bg-slate-900 text-slate-50 px-6 py-7 space-y-4 shadow-sm">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <span>🚀</span>
        <span>Netflix con perfil propio · Argentina · Precio en pesos</span>
      </h2>
      <div class="flex flex-wrap gap-2">
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Perfil tuyo solo</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Precio en pesos</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Sin compartir</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Sin tarjeta internacional</span>
      </div>
      <a href={PAY_URL} class="inline-flex items-center justify-center rounded-xl bg-violet-600 hover:bg-violet-700 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
        Consultar / Comprar →
      </a>
      <p class="text-[11px] text-slate-400 pt-1">CuentasDigitales.com.ar no es Netflix ni está afiliado a la marca.</p>
    </section>

  </section>
</BaseLayout>
