---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Pagar Netflix con Mercado Pago en Argentina (2026)";
const description = "Netflix no acepta Mercado Pago directamente. Pero podés acceder a Netflix pagando con Mercado Pago a través de CuentasDigitales.com.ar. Precio en pesos, sin tarjeta internacional, sin impuestos del 51%.";
const url = "https://cuentasdigitales.com.ar/cuentas-digitales/netflix-argentina-pago-mercadopago";

const priceARS = 20000;
const priceCurrency = "ARS";
const PRODUCT_NAME = "Netflix Argentina pago Mercado Pago";
const PRODUCT_AMOUNT = 20000;
const PAY_URL = `/pago?item=${encodeURIComponent(PRODUCT_NAME)}&amount=${PRODUCT_AMOUNT}&currency=ARS`;
---

<BaseLayout
  title={title}
  description={description}
  type="product"
  canonical="/cuentas-digitales/netflix-argentina-pago-mercadopago"
  ogImage="/images/netflix-prepago-argentina.jpg"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Product",
      name: "Netflix Argentina pago Mercado Pago",
      description,
      brand: { "@type": "Organization", name: "Netflix" },
      url,
      category: "Suscripciones digitales",
      image: ["https://cuentasdigitales.com.ar/images/netflix-prepago-argentina.jpg"],
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "4.9",
        reviewCount: "53",
        bestRating: "5",
        worstRating: "1",
      },
      review: [
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          author: { "@type": "Person", name: "Alejandro M." },
          reviewBody: "Todo mi manejo de plata es por Mercado Pago. Poder pagar Netflix también por ahí me facilitó un montón la vida.",
          datePublished: "2026-03-01",
        },
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          author: { "@type": "Person", name: "Natalia P." },
          reviewBody: "Pagué con saldo de Mercado Pago y Netflix quedó activado en minutos. Super recomendable.",
          datePublished: "2026-02-20",
        },
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          author: { "@type": "Person", name: "Gonzalo F." },
          reviewBody: "No tengo tarjeta de crédito pero tengo Mercado Pago siempre cargado. Esta opción me salvó.",
          datePublished: "2026-01-15",
        },
      ],
      offers: {
        "@type": "Offer",
        url,
        priceCurrency,
        price: String(priceARS),
        priceValidUntil: "2026-12-31",
        availability: "https://schema.org/InStock",
        itemCondition: "https://schema.org/NewCondition",
        seller: { "@type": "Organization", name: "CuentasDigitales.com.ar" },
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "¿Se puede pagar Netflix con Mercado Pago en Argentina?",
          acceptedAnswer: { "@type": "Answer", text: "Netflix no acepta Mercado Pago directamente. Pero podés pagar Netflix usando Mercado Pago a través de CuentasDigitales.com.ar, que sí acepta ese medio de pago para gestionar el acceso." },
        },
        {
          "@type": "Question",
          name: "¿Por qué Netflix no acepta Mercado Pago directo?",
          acceptedAnswer: { "@type": "Answer", text: "Netflix no tiene acuerdos de integración con Mercado Pago en Argentina, a diferencia de Disney+ o Amazon Prime que sí los tienen. Netflix solo acepta tarjetas Visa/Mastercard habilitadas para pagos internacionales." },
        },
      ],
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: "https://cuentasdigitales.com.ar/" },
        { "@type": "ListItem", position: 2, name: "Cuentas Premium", item: "https://cuentasdigitales.com.ar/cuentas-digitales/" },
        { "@type": "ListItem", position: 3, name: title, item: url },
      ],
    },
  ]}
>
  {/* HERO */}
  <section class="mb-12">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-3xl bg-gradient-to-br from-slate-900 to-cyan-900 text-slate-50 shadow-xl overflow-hidden">
        <div class="p-7 md:p-10 space-y-4 max-w-2xl">
          <p class="inline-flex items-center gap-2 text-xs md:text-sm bg-slate-800/70 border border-cyan-400/60 rounded-full px-3 py-1 w-fit">
            <span>💚</span>
            <span>Netflix + Mercado Pago · Argentina 🇦🇷</span>
          </p>
          <h1 class="text-3xl md:text-4xl font-extrabold leading-snug">
            Pagar Netflix con Mercado Pago en Argentina
          </h1>
          <div class="rounded-2xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-slate-200/90">
            <p class="font-semibold text-slate-100">👉 Netflix no acepta MP directo, pero nosotros sí</p>
            <p>Pagás con tu saldo de Mercado Pago, nosotros gestionamos el acceso. Precio en pesos, sin tarjeta internacional, sin el 51% de impuestos encima.</p>
          </div>
          <ul class="text-xs md:text-sm text-slate-200/90 space-y-1 pt-1">
            <li>✅ Pagás con saldo de Mercado Pago en pesos.</li>
            <li>✅ Sin tarjeta de crédito ni cuenta bancaria requerida.</li>
            <li>✅ Sin el 51% de impuestos que aplica Netflix directo.</li>
            <li>✅ Activación rápida con soporte local.</li>
          </ul>
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a href={PAY_URL} class="inline-flex items-center justify-center rounded-xl bg-cyan-600 hover:bg-cyan-700 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
              Consultar / Comprar →
            </a>
          </div>
          <p class="text-xs text-slate-400 pt-1">Precio de referencia: <strong>${priceARS.toLocaleString("es-AR")} ARS</strong> (puede variar según disponibilidad).</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto pb-16 space-y-9">

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-4">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>🤔</span>
        <span>¿Por qué Netflix no acepta Mercado Pago directamente?</span>
      </h2>
      <p class="text-slate-700 text-[15px] leading-relaxed">
        Mercado Pago es el método de pago digital más usado en Argentina, pero Netflix no tiene integración con él. La razón es que Netflix solo opera con redes de tarjetas internacionales (Visa y Mastercard globales) para sus cobros recurrentes.
      </p>
      <p class="text-slate-700 text-[15px] leading-relaxed">
        Es curioso que Disney+, Amazon Prime y Max sí tienen acuerdos con Mercado Pago que permiten pagar directamente, pero Netflix históricamente se mantuvo fuera de esos acuerdos en Argentina.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-slate-100 text-slate-700 text-left">
              <th class="px-3 py-2 rounded-tl-xl">Plataforma</th>
              <th class="px-3 py-2 text-center rounded-tr-xl">¿Acepta MP directo?</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 text-slate-700">
            <tr class="bg-red-50">
              <td class="px-3 py-2 font-semibold">🔴 Netflix</td>
              <td class="px-3 py-2 text-center text-red-500">No ❌</td>
            </tr>
            <tr>
              <td class="px-3 py-2">🔵 Disney+</td>
              <td class="px-3 py-2 text-center text-green-500">Sí ✅</td>
            </tr>
            <tr>
              <td class="px-3 py-2">🟠 Amazon Prime</td>
              <td class="px-3 py-2 text-center text-green-500">Sí ✅</td>
            </tr>
            <tr>
              <td class="px-3 py-2 rounded-bl-xl">🟣 Max</td>
              <td class="px-3 py-2 text-center text-green-500 rounded-br-xl">Sí ✅</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-5">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>⚙️</span>
        <span>Cómo pagar Netflix con Mercado Pago a través de nosotros</span>
      </h2>
      <ol class="list-decimal list-inside text-slate-700 text-[15px] leading-relaxed space-y-2">
        <li>Consultás disponibilidad desde el botón de esta página.</li>
        <li>Te confirmamos precio en pesos y el link de pago por Mercado Pago.</li>
        <li><strong>Pagás con tu saldo de Mercado Pago</strong> — sin necesidad de vincular tarjeta.</li>
        <li>Activamos el acceso a Netflix y te guiamos para entrar.</li>
        <li>Usás Netflix por el período elegido. Sin renovación automática.</li>
      </ol>
      <div class="rounded-2xl bg-cyan-50 border border-cyan-100 px-4 py-3 text-sm text-slate-700">
        💡 Podés pagar desde la app de Mercado Pago con saldo disponible, sin vincular ninguna tarjeta. Si tu saldo está en pesos, pagás en pesos.
      </div>
    </section>

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-4">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>💰</span>
        <span>¿Qué ventaja tiene pagar por acá vs Netflix con tarjeta?</span>
      </h2>
      <p class="text-slate-700 text-[15px]">Cuando pagás Netflix directo con tarjeta, el sistema aplica impuestos automáticamente. Con Mercado Pago a través de CuentasDigitales, el precio ya está definido en pesos:</p>
      <div class="grid gap-3 md:grid-cols-2 text-sm">
        <div class="rounded-xl bg-red-50 border border-red-100 px-4 py-3">
          <p class="font-semibold text-slate-800 mb-1">😤 Netflix con tarjeta directa</p>
          <ul class="list-disc list-inside space-y-1 text-slate-600">
            <li>Precio base + 51% impuestos.</li>
            <li>Varía con el tipo de cambio.</li>
            <li>Renovación automática mensual.</li>
            <li>Muchas tarjetas rechazadas.</li>
          </ul>
        </div>
        <div class="rounded-xl bg-green-50 border border-green-100 px-4 py-3">
          <p class="font-semibold text-slate-800 mb-1">✅ Mercado Pago vía CuentasDigitales</p>
          <ul class="list-disc list-inside space-y-1 text-slate-600">
            <li>Precio fijo en pesos.</li>
            <li>Sin variación por dólar.</li>
            <li>Sin renovación automática.</li>
            <li>MP siempre funciona.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="rounded-3xl bg-slate-900 text-slate-50 px-6 py-7 space-y-4 shadow-sm">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <span>🚀</span>
        <span>Netflix con Mercado Pago · Argentina</span>
      </h2>
      <div class="flex flex-wrap gap-2">
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Pagá con MP</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Sin tarjeta</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Precio en pesos</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Activación rápida</span>
      </div>
      <a href={PAY_URL} class="inline-flex items-center justify-center rounded-xl bg-cyan-600 hover:bg-cyan-700 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
        Consultar / Comprar →
      </a>
      <p class="text-[11px] text-slate-400 pt-1">CuentasDigitales.com.ar no es Netflix ni está afiliado a la marca.</p>
    </section>

  </section>
</BaseLayout>
