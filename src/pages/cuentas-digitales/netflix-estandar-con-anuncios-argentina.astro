---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Netflix Estándar con anuncios Argentina 2026 — El más barato";
const description = "Netflix Estándar con anuncios es el plan más barato disponible en Argentina desde que eliminaron el Básico. Full HD, 2 pantallas, precio en pesos sin el recargo del 51% de impuestos.";
const url = "https://cuentasdigitales.com.ar/cuentas-digitales/netflix-estandar-con-anuncios-argentina";

const priceARS = 13000;
const priceCurrency = "ARS";
const PRODUCT_NAME = "Netflix Estándar con anuncios Argentina";
const PRODUCT_AMOUNT = 13000;
const PAY_URL = `/pago?item=${encodeURIComponent(PRODUCT_NAME)}&amount=${PRODUCT_AMOUNT}&currency=ARS`;
---

<BaseLayout
  title={title}
  description={description}
  type="product"
  canonical="/cuentas-digitales/netflix-estandar-con-anuncios-argentina"
  ogImage="/images/netflix-prepago-argentina.jpg"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Product",
      name: "Netflix Estándar con anuncios Argentina",
      description,
      brand: { "@type": "Organization", name: "Netflix" },
      url,
      category: "Suscripciones digitales",
      image: ["https://cuentasdigitales.com.ar/images/netflix-prepago-argentina.jpg"],
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "4.5",
        reviewCount: "22",
        bestRating: "5",
        worstRating: "1",
      },
      review: [
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          author: { "@type": "Person", name: "Tomás V." },
          reviewBody: "Para el precio que sale no me puedo quejar. Los anuncios son pocos y no molestan tanto. Perfecto para el bolsillo.",
          datePublished: "2026-03-15",
        },
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "4", bestRating: "5" },
          author: { "@type": "Person", name: "Carolina B." },
          reviewBody: "Lo uso para ver series de fondo mientras hago otras cosas. Los anuncios no me molestan y el precio en pesos es muy cómodo.",
          datePublished: "2026-02-28",
        },
      ],
      offers: {
        "@type": "Offer",
        url,
        priceCurrency,
        price: String(priceARS),
        priceValidUntil: "2026-12-31",
        availability: "https://schema.org/InStock",
        itemCondition: "https://schema.org/NewCondition",
        seller: { "@type": "Organization", name: "CuentasDigitales.com.ar" },
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "¿Cuántos anuncios tiene Netflix Estándar con anuncios en Argentina?",
          acceptedAnswer: { "@type": "Answer", text: "Netflix incluye entre 4 y 5 minutos de publicidad por hora de contenido aproximadamente. Los anuncios aparecen antes y durante los programas, no al final." },
        },
        {
          "@type": "Question",
          name: "¿El plan con anuncios tiene acceso a todo el catálogo de Netflix?",
          acceptedAnswer: { "@type": "Answer", text: "Casi todo. Hay un pequeño porcentaje del catálogo que no está disponible en el plan con anuncios por restricciones de licencia. La gran mayoría del contenido sí está disponible." },
        },
        {
          "@type": "Question",
          name: "¿Cuánto cuesta Netflix con anuncios en Argentina con impuestos?",
          acceptedAnswer: { "@type": "Answer", text: "El plan Estándar con anuncios cuesta ~$10.900 base. Con el 51% de impuestos (IVA + Ganancias), el precio real al contratar directamente llega a ~$16.460 por mes." },
        },
      ],
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: "https://cuentasdigitales.com.ar/" },
        { "@type": "ListItem", position: 2, name: "Cuentas Premium", item: "https://cuentasdigitales.com.ar/cuentas-digitales/" },
        { "@type": "ListItem", position: 3, name: title, item: url },
      ],
    },
  ]}
>
  {/* HERO */}
  <section class="mb-12">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-3xl bg-gradient-to-br from-slate-900 to-green-900 text-slate-50 shadow-xl overflow-hidden">
        <div class="p-7 md:p-10 space-y-4 max-w-2xl">
          <p class="inline-flex items-center gap-2 text-xs md:text-sm bg-slate-800/70 border border-green-400/60 rounded-full px-3 py-1 w-fit">
            <span>💰</span>
            <span>El más barato de Netflix · Argentina 🇦🇷</span>
          </p>

          <h1 class="text-3xl md:text-4xl font-extrabold leading-snug">
            Netflix con anuncios en Argentina
          </h1>

          <div class="rounded-2xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-slate-200/90">
            <p class="font-semibold text-slate-100">👉 La opción más económica disponible</p>
            <p>Desde que Netflix eliminó el plan Básico, el Estándar con anuncios es la entrada más accesible. Full HD, 2 pantallas y precio en pesos sin el recargo del 51%.</p>
          </div>

          <ul class="text-xs md:text-sm text-slate-200/90 space-y-1 pt-1">
            <li>✅ El plan más barato disponible en Netflix Argentina 2026.</li>
            <li>✅ Full HD · 2 pantallas · Casi todo el catálogo.</li>
            <li>✅ Precio fijo en pesos, sin impuestos variables.</li>
            <li>✅ Sin tarjeta internacional ni renovación automática.</li>
          </ul>

          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a href={PAY_URL} class="inline-flex items-center justify-center rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
              Consultar / Comprar →
            </a>
          </div>

          <p class="text-xs text-slate-400 pt-1">
            Precio de referencia: <strong>${priceARS.toLocaleString("es-AR")} ARS</strong> (puede variar según disponibilidad).
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto pb-16 space-y-9">

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-4">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>📢</span>
        <span>¿Qué tan molestos son los anuncios en Netflix?</span>
      </h2>
      <p class="text-slate-700 text-[15px] leading-relaxed">
        Es la pregunta clave antes de elegir este plan. La respuesta honesta: depende de tu tolerancia y de lo que mirés. Netflix con anuncios incluye <strong>entre 4 y 5 minutos de publicidad por hora</strong> de contenido. Los anuncios aparecen al inicio y en pausas durante el contenido.
      </p>
      <div class="space-y-3 text-sm">
        <div class="rounded-xl bg-green-50 border border-green-100 px-4 py-3">
          <p class="font-semibold text-slate-800">✅ Casos donde los anuncios casi no molestan</p>
          <ul class="list-disc list-inside mt-1 text-slate-600 space-y-1">
            <li>Ver contenido de fondo mientras hacés otra cosa.</li>
            <li>Series con episodios largos (los cortes son menos frecuentes).</li>
            <li>Películas donde la interrupción es menor en proporción.</li>
            <li>Usuarios que ya están acostumbrados a YouTube o TV abierta.</li>
          </ul>
        </div>
        <div class="rounded-xl bg-amber-50 border border-amber-100 px-4 py-3">
          <p class="font-semibold text-slate-800">⚠️ Casos donde sí puede molestar</p>
          <ul class="list-disc list-inside mt-1 text-slate-600 space-y-1">
            <li>Series de episodios cortos (los anuncios son más frecuentes en proporción).</li>
            <li>Maratonear muchos episodios seguidos.</li>
            <li>Personas muy sensibles a las interrupciones.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-4">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>💰</span>
        <span>¿Cuánto ahorrás eligiendo este plan?</span>
      </h2>
      <p class="text-slate-700 text-[15px]">Comparando todos los caminos posibles para ver Netflix en Argentina:</p>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between items-center rounded-xl bg-red-50 border border-red-100 px-4 py-3">
          <span class="text-slate-700">Netflix Estándar directo (con impuestos)</span>
          <span class="font-bold text-red-600">~$31.710/mes</span>
        </div>
        <div class="flex justify-between items-center rounded-xl bg-amber-50 border border-amber-100 px-4 py-3">
          <span class="text-slate-700">Netflix con anuncios directo (con impuestos)</span>
          <span class="font-bold text-amber-600">~$16.460/mes</span>
        </div>
        <div class="flex justify-between items-center rounded-xl bg-green-50 border border-green-100 px-4 py-3">
          <span class="text-slate-700 font-semibold">Con anuncios vía CuentasDigitales</span>
          <span class="font-bold text-green-600">${priceARS.toLocaleString("es-AR")} ARS</span>
        </div>
      </div>
      <p class="text-xs text-slate-400">* Comparativa orientativa. El precio oficial varía con el tipo de cambio.</p>
    </section>

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-5">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>⚙️</span>
        <span>Cómo funciona el proceso</span>
      </h2>
      <ol class="list-decimal list-inside text-slate-700 text-[15px] leading-relaxed space-y-2">
        <li>Consultás disponibilidad desde el botón de esta página.</li>
        <li>Te confirmamos precio en pesos y medios de pago disponibles.</li>
        <li>Pagás en ARS — transferencia, Mercado Pago u otros medios locales.</li>
        <li>Activamos el acceso y te guiamos para entrar a Netflix.</li>
        <li>Usás Netflix con anuncios sin sorpresas de precio ni renovación automática.</li>
      </ol>
    </section>

    <section class="rounded-3xl bg-slate-900 text-slate-50 px-6 py-7 space-y-4 shadow-sm">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <span>🚀</span>
        <span>Netflix con anuncios · Argentina · Precio en pesos</span>
      </h2>
      <div class="flex flex-wrap gap-2">
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ El más barato</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Full HD</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ 2 pantallas</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Precio en pesos</span>
      </div>
      <p class="text-sm md:text-[15px] text-slate-100/90">
        La opción más económica para ver Netflix en Argentina con precio fijo en pesos.
      </p>
      <a href={PAY_URL} class="inline-flex items-center justify-center rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
        Consultar / Comprar →
      </a>
      <p class="text-[11px] text-slate-400 pt-1">CuentasDigitales.com.ar no es Netflix ni está afiliado a la marca.</p>
    </section>

  </section>
</BaseLayout>
