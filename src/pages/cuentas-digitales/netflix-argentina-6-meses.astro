---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Netflix 6 meses Argentina — Precio en pesos, el más conveniente";
const description = "Accedé a Netflix por 6 meses en Argentina con precio fijo en pesos. El período más conveniente para quienes usan Netflix todo el año. Sin renovación automática, sin impuestos del 51%, sin tarjeta internacional.";
const url = "https://cuentasdigitales.com.ar/cuentas-digitales/netflix-argentina-6-meses";

const priceARS = 100000;
const priceCurrency = "ARS";
const PRODUCT_NAME = "Netflix 6 meses Argentina";
const PRODUCT_AMOUNT = 100000;
const PAY_URL = `/pago?item=${encodeURIComponent(PRODUCT_NAME)}&amount=${PRODUCT_AMOUNT}&currency=ARS`;
---

<BaseLayout
  title={title}
  description={description}
  type="product"
  canonical="/cuentas-digitales/netflix-argentina-6-meses"
  ogImage="/images/netflix-prepago-argentina.jpg"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "Product",
      name: "Netflix 6 meses Argentina",
      description,
      brand: { "@type": "Organization", name: "Netflix" },
      url,
      category: "Suscripciones digitales",
      image: ["https://cuentasdigitales.com.ar/images/netflix-prepago-argentina.jpg"],
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "4.9",
        reviewCount: "19",
        bestRating: "5",
        worstRating: "1",
      },
      review: [
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          author: { "@type": "Person", name: "Nicolás B." },
          reviewBody: "Lo tomé por 6 meses porque sé que lo uso seguido. Resuelvo esto por medio año y me olvido. Mucho más práctico que renovar todos los meses.",
          datePublished: "2026-03-10",
        },
        {
          "@type": "Review",
          reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
          author: { "@type": "Person", name: "Valentina C." },
          reviewBody: "El precio por mes sale mucho mejor que tomarlo de a uno. Y con precio fijo en pesos no me preocupa si Netflix vuelve a subir.",
          datePublished: "2026-02-28",
        },
      ],
      offers: {
        "@type": "Offer",
        url,
        priceCurrency,
        price: String(priceARS),
        priceValidUntil: "2026-12-31",
        availability: "https://schema.org/InStock",
        itemCondition: "https://schema.org/NewCondition",
        seller: { "@type": "Organization", name: "CuentasDigitales.com.ar" },
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "¿Cuánto conviene Netflix 6 meses en Argentina vs mes a mes?",
          acceptedAnswer: { "@type": "Answer", text: "El período de 6 meses ofrece el mejor precio por mes de todas las opciones disponibles. Además, fijás el precio en pesos por medio año y te protegés de los aumentos que Netflix aplica frecuentemente en Argentina." },
        },
        {
          "@type": "Question",
          name: "¿Qué pasa si Netflix aumenta de precio durante los 6 meses?",
          acceptedAnswer: { "@type": "Answer", text: "Con la modalidad de precio fijo en pesos, el aumento de Netflix no te afecta durante el período contratado. El precio que acordaste es el que pagás." },
        },
      ],
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: "https://cuentasdigitales.com.ar/" },
        { "@type": "ListItem", position: 2, name: "Cuentas Premium", item: "https://cuentasdigitales.com.ar/cuentas-digitales/" },
        { "@type": "ListItem", position: 3, name: title, item: url },
      ],
    },
  ]}
>
  {/* HERO */}
  <section class="mb-12">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-3xl bg-gradient-to-br from-slate-900 to-emerald-900 text-slate-50 shadow-xl overflow-hidden">
        <div class="p-7 md:p-10 space-y-4 max-w-2xl">
          <p class="inline-flex items-center gap-2 text-xs md:text-sm bg-slate-800/70 border border-emerald-400/60 rounded-full px-3 py-1 w-fit">
            <span>📆</span>
            <span>Netflix 6 meses · El más conveniente · Argentina 🇦🇷</span>
          </p>
          <h1 class="text-3xl md:text-4xl font-extrabold leading-snug">
            Netflix por 6 meses en Argentina
          </h1>
          <div class="rounded-2xl bg-white/5 border border-white/10 px-4 py-3 text-sm text-slate-200/90">
            <p class="font-semibold text-slate-100">👉 El mejor precio por mes disponible</p>
            <p>Pagás una vez por medio año. Sin renovar, sin acordarte, sin que los aumentos de Netflix te afecten durante el período. Precio fijo en pesos.</p>
          </div>
          <ul class="text-xs md:text-sm text-slate-200/90 space-y-1 pt-1">
            <li>✅ 6 meses fijos desde la activación.</li>
            <li>✅ El mejor precio por mes de todas las opciones.</li>
            <li>✅ Los aumentos de Netflix no te afectan durante el período.</li>
            <li>✅ Sin renovación automática al finalizar.</li>
          </ul>
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a href={PAY_URL} class="inline-flex items-center justify-center rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
              Consultar / Comprar →
            </a>
            <a href="/cuentas-digitales/cuenta-netflix-trimestral-argentina" class="inline-flex items-center justify-center rounded-xl bg-white/10 hover:bg-white/15 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
              Ver opción 3 meses
            </a>
          </div>
          <p class="text-xs text-slate-400 pt-1">Precio de referencia: <strong>${priceARS.toLocaleString("es-AR")} ARS</strong> por 6 meses (puede variar según disponibilidad).</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto pb-16 space-y-9">

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-4">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>🧮</span>
        <span>Comparativa de períodos: ¿qué conviene más?</span>
      </h2>
      <p class="text-slate-700 text-[15px]">Cuanto más largo el período, mejor el precio por mes. Así queda la comparativa:</p>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between items-center rounded-xl bg-slate-50 border border-slate-200 px-4 py-3">
          <span class="text-slate-700 font-medium">1 mes</span>
          <span class="text-slate-500">$20.000/mes</span>
        </div>
        <div class="flex justify-between items-center rounded-xl bg-slate-50 border border-slate-200 px-4 py-3">
          <span class="text-slate-700 font-medium">3 meses</span>
          <span class="text-slate-500">~$18.333/mes</span>
        </div>
        <div class="flex justify-between items-center rounded-xl bg-emerald-50 border border-emerald-200 px-4 py-3">
          <span class="text-slate-700 font-semibold">6 meses ✅</span>
          <span class="font-bold text-emerald-700">~$16.667/mes</span>
        </div>
      </div>
      <p class="text-xs text-slate-400">* Precios de referencia orientativos. Consultar disponibilidad para valores exactos.</p>

      <div class="rounded-2xl bg-emerald-50 border border-emerald-100 px-4 py-3 text-sm text-slate-700">
        <p class="font-semibold mb-1">🛡️ El beneficio extra que no suma pero igual vale</p>
        <p>Con precio fijo por 6 meses, quedás protegido de los aumentos que Netflix aplique durante ese período. En 2025 hubo tres aumentos en Argentina. Con precio fijo, eso no te afecta.</p>
      </div>
    </section>

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-4">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>🤔</span>
        <span>¿Para quién tiene sentido el período de 6 meses?</span>
      </h2>
      <div class="space-y-2 text-[15px] text-slate-700">
        <div class="flex items-start gap-2">
          <span class="text-emerald-500 mt-0.5">✓</span>
          <p>Quienes <strong>usan Netflix todo el año</strong> y saben que no van a cortarlo.</p>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-emerald-500 mt-0.5">✓</span>
          <p>Los que quieren <strong>olvidarse de renovar</strong> por un buen tiempo.</p>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-emerald-500 mt-0.5">✓</span>
          <p>Quienes quieren <strong>precio fijo</strong> ante los aumentos frecuentes de Netflix en Argentina.</p>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-emerald-500 mt-0.5">✓</span>
          <p>Los que buscan el <strong>costo por mes más bajo</strong> disponible.</p>
        </div>
      </div>
    </section>

    <section class="rounded-3xl bg-white/95 shadow-sm border border-slate-200 px-6 py-7 space-y-5">
      <h2 class="text-xl md:text-2xl font-bold text-slate-900 flex items-center gap-2">
        <span>⚙️</span>
        <span>Cómo funciona el proceso</span>
      </h2>
      <ol class="list-decimal list-inside text-slate-700 text-[15px] leading-relaxed space-y-2">
        <li>Consultás disponibilidad desde el botón de esta página.</li>
        <li>Te confirmamos precio en pesos por los 6 meses y medios de pago.</li>
        <li>Pagás en ARS — transferencia, Mercado Pago u otro medio local.</li>
        <li>Activamos el acceso y empieza el período de 6 meses.</li>
        <li>Al finalizar, sin renovación automática. Decidís vos si continuás.</li>
      </ol>
    </section>

    <section class="rounded-3xl bg-slate-900 text-slate-50 px-6 py-7 space-y-4 shadow-sm">
      <h2 class="text-xl md:text-2xl font-bold flex items-center gap-2">
        <span>🚀</span>
        <span>Netflix 6 meses · Argentina · El más conveniente</span>
      </h2>
      <div class="flex flex-wrap gap-2">
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ 6 meses fijos</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Mejor precio/mes</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Precio fijo en pesos</span>
        <span class="text-[11px] bg-white/10 border border-white/10 rounded-full px-3 py-1">✅ Sin renovación automática</span>
      </div>
      <a href={PAY_URL} class="inline-flex items-center justify-center rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2.5 px-5 text-sm md:text-base transition-colors">
        Consultar / Comprar →
      </a>
      <p class="text-[11px] text-slate-400 pt-1">CuentasDigitales.com.ar no es Netflix ni está afiliado a la marca.</p>
    </section>

  </section>
</BaseLayout>
