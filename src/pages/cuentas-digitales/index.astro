---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Cuentas premium de streaming en Argentina — CuentasDigitales";
const description =
  "Cuentas digitales para Argentina: cuenta Netflix, cuenta Spotify, cuenta Disney+, cuenta HBO Max, cuenta Amazon Prime, cuenta YouTube Premium y más. Pagás en pesos, por 1 o 3 meses, sin tarjeta internacional.";

const platforms = [
  {
    brand: "Netflix", emoji: "🎬", tagColor: "text-red-700 bg-red-50 border-red-100",
    products: [
      { slug: "cuenta-netflix-argentina", tag: "Premium ARS", title: "Cuenta Netflix Argentina — precio final en pesos", desc: "Netflix premium con impuestos incluidos, precio final en ARS y soporte local." },
      { slug: "cuenta-netflix-argentina-1-mes", tag: "1 mes prepago", title: "Netflix 1 mes prepago", desc: "Un mes sin renovación automática, pagás en pesos con métodos locales." },
      { slug: "cuenta-netflix-argentina-3-meses", tag: "3 meses prepago", title: "Netflix 3 meses prepago", desc: "Tres meses al mejor precio, sin drama de tarjeta ni dólar." },
      { slug: "comprar-cuenta-netflix-argentina", tag: "Comprar ahora", title: "Comprar cuenta Netflix Argentina", desc: "Precio en pesos, sin tarjeta internacional, sin el 51% de impuestos." },
      { slug: "netflix-premium-4-pantallas-argentina", tag: "4 pantallas · 4K", title: "Netflix Premium 4 pantallas Argentina", desc: "Ultra HD, Dolby Atmos, 4 pantallas simultáneas. Precio en pesos." },
      { slug: "netflix-estandar-argentina", tag: "2 pantallas · Sin anuncios", title: "Netflix Estándar Argentina", desc: "Full HD, 2 pantallas, sin publicidad. Precio fijo en pesos." },
      { slug: "netflix-estandar-con-anuncios-argentina", tag: "El más barato", title: "Netflix con anuncios Argentina", desc: "La opción más económica desde que eliminaron el Básico. Full HD, 2 pantallas." },
      { slug: "netflix-argentina-sin-tarjeta", tag: "Sin tarjeta", title: "Netflix Argentina sin tarjeta de crédito", desc: "Pagá con transferencia o Mercado Pago. Sin tarjeta internacional necesaria." },
      { slug: "netflix-argentina-precio-pesos", tag: "Precio en pesos", title: "Netflix Argentina precio en pesos 2026", desc: "Precio fijo en pesos sin el 51% de impuestos. Sin variación por tipo de cambio." },
      { slug: "netflix-argentina-pago-mercadopago", tag: "Mercado Pago", title: "Pagar Netflix con Mercado Pago Argentina", desc: "Netflix no acepta MP directo, pero nosotros sí. Pagá con tu saldo en pesos." },
      { slug: "cuenta-netflix-compartida-argentina", tag: "Acceso propio", title: "Cuenta Netflix compartida Argentina", desc: "¿Te sacaron de la cuenta compartida? Tenés acceso independiente con precio en pesos." },
      { slug: "cuenta-netflix-perfil-propio-argentina", tag: "Perfil propio", title: "Netflix con perfil propio Argentina", desc: "Tus listas, tu historial, tus recomendaciones. Sin compartir con nadie." },
      { slug: "cuenta-netflix-trimestral-argentina", tag: "3 meses", title: "Netflix trimestral Argentina", desc: "Mejor precio por mes que la opción mensual. Ideal también como regalo." },
      { slug: "netflix-argentina-6-meses", tag: "6 meses · Más conveniente", title: "Netflix 6 meses Argentina", desc: "El mejor precio por mes disponible. Protegido de aumentos por medio año." },
      { slug: "netflix-4-pantallas-argentina", tag: "Ultra HD 4K", title: "Netflix 4 pantallas Argentina", desc: "Solo el Premium tiene 4 pantallas y Ultra HD real. Precio en pesos." },
    ],
  },
  {
    brand: "Spotify", emoji: "🎵", tagColor: "text-green-700 bg-green-50 border-green-100",
    products: [
      { slug: "cuenta-spotify-argentina-1-mes", tag: "1 mes prepago", title: "Spotify 1 mes prepago", desc: "Un mes de Spotify Premium en pesos, sin renovación automática." },
      { slug: "cuenta-spotify-argentina-3-meses", tag: "3 meses prepago", title: "Spotify 3 meses prepago", desc: "Tres meses de Spotify a precio conveniente, pagás en ARS." },
    ],
  },
  {
    brand: "Disney+", emoji: "🏰", tagColor: "text-blue-700 bg-blue-50 border-blue-100",
    products: [
      { slug: "cuenta-disney-plus-argentina-1-mes", tag: "1 mes prepago", title: "Disney+ 1 mes prepago", desc: "Un mes de Disney+, Star Wars, Marvel y más. Pagás en pesos." },
      { slug: "cuenta-disney-plus-argentina-3-meses", tag: "3 meses prepago", title: "Disney+ 3 meses prepago", desc: "Tres meses de Disney+ sin lío de tarjeta internacional." },
    ],
  },
  {
    brand: "Max (HBO Max)", emoji: "🎭", tagColor: "text-purple-700 bg-purple-50 border-purple-100",
    products: [
      { slug: "cuenta-hbo-max-argentina-1-mes", tag: "1 mes prepago", title: "Max 1 mes prepago", desc: "Un mes de Max (HBO) en pesos. Series exclusivas sin complicaciones." },
      { slug: "cuenta-hbo-max-argentina-3-meses", tag: "3 meses prepago", title: "Max 3 meses prepago", desc: "Tres meses de Max al mejor precio, pagás en ARS." },
    ],
  },
  {
    brand: "Amazon Prime Video", emoji: "📦", tagColor: "text-yellow-700 bg-yellow-50 border-yellow-100",
    products: [
      { slug: "cuenta-amazon-prime-argentina-1-mes", tag: "1 mes prepago", title: "Amazon Prime Video 1 mes", desc: "Un mes de Prime Video en pesos, sin tarjeta internacional." },
      { slug: "cuenta-amazon-prime-argentina-3-meses", tag: "3 meses prepago", title: "Amazon Prime Video 3 meses", desc: "Tres meses de Prime Video a precio conveniente en ARS." },
    ],
  },
  {
    brand: "YouTube Premium", emoji: "▶️", tagColor: "text-red-700 bg-red-50 border-red-100",
    products: [
      { slug: "cuenta-youtube-premium-argentina-1-mes", tag: "1 mes prepago", title: "YouTube Premium 1 mes", desc: "Un mes sin anuncios y con YouTube Music. Pagás en pesos." },
      { slug: "cuenta-youtube-premium-argentina-3-meses", tag: "3 meses prepago", title: "YouTube Premium 3 meses", desc: "Tres meses de YouTube Premium sin interrupciones, en ARS." },
    ],
  },
  {
    brand: "Crunchyroll", emoji: "⛩️", tagColor: "text-orange-700 bg-orange-50 border-orange-100",
    products: [
      { slug: "cuenta-crunchyroll-argentina-1-mes", tag: "1 mes prepago", title: "Crunchyroll 1 mes prepago", desc: "Un mes de anime sin límites. Pagás en pesos, sin tarjeta extranjera." },
      { slug: "cuenta-crunchyroll-argentina-3-meses", tag: "3 meses prepago", title: "Crunchyroll 3 meses prepago", desc: "Tres meses de Crunchyroll a precio conveniente, pagás en ARS." },
    ],
  },
  {
    brand: "Paramount+", emoji: "⭐", tagColor: "text-blue-700 bg-blue-50 border-blue-100",
    products: [
      { slug: "cuenta-paramount-plus-argentina-1-mes", tag: "1 mes prepago", title: "Paramount+ 1 mes prepago", desc: "Un mes de Paramount+ en pesos. Yellowstone, Star Trek y más." },
      { slug: "cuenta-paramount-plus-argentina-3-meses", tag: "3 meses prepago", title: "Paramount+ 3 meses prepago", desc: "Tres meses de Paramount+ sin drama de tarjeta, pagás en ARS." },
    ],
  },
  {
    brand: "Apple TV+", emoji: "🍎", tagColor: "text-slate-700 bg-slate-50 border-slate-200",
    products: [
      { slug: "cuenta-apple-tv-argentina-1-mes", tag: "1 mes prepago", title: "Apple TV+ 1 mes prepago", desc: "Un mes de Apple TV+ en pesos. Severance, Ted Lasso y más." },
      { slug: "cuenta-apple-tv-argentina-3-meses", tag: "3 meses prepago", title: "Apple TV+ 3 meses prepago", desc: "Tres meses de Apple TV+ a precio conveniente, sin tarjeta extranjera." },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/cuentas-digitales"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: "https://cuentasdigitales.com.ar/" },
        { "@type": "ListItem", position: 2, name: "Cuentas Premium", item: "https://cuentasdigitales.com.ar/cuentas-digitales/" },
      ],
    },
  ]}
>
  {/* HERO */}
  <section class="mb-10">
    <div class="max-w-4xl mx-auto">
      <div class="rounded-3xl bg-gradient-to-r from-slate-900 via-slate-900 to-red-700 text-slate-50 px-6 py-8 md:px-10 md:py-10 shadow-lg">
        <div class="space-y-4">
          <p class="inline-flex items-center gap-2 text-xs md:text-sm bg-slate-800/70 border border-red-400/60 rounded-full px-3 py-1">
            <span>⭐</span>
            <span>Cuentas premium y planes prepagos · Argentina</span>
          </p>
          <h1 class="text-3xl md:text-4xl font-extrabold leading-snug">
            Cuentas premium de streaming para Argentina
          </h1>
          <p class="text-sm md:text-base text-slate-100/90 max-w-2xl">
            Netflix, Spotify, Disney+, HBO Max, Amazon Prime, YouTube Premium, Crunchyroll, Paramount+ y Apple TV+ en modalidad prepaga. Pagás en pesos, por 1 o 3 meses, con medios de pago locales. Sin tarjeta internacional, sin lío de dólar.
          </p>
          <ul class="text-xs md:text-sm text-slate-100/90 space-y-1">
            <li>✅ Modalidad prepaga: pagás por 1 o 3 meses definidos.</li>
            <li>✅ Precio en pesos, con métodos de pago locales.</li>
            <li>✅ Sin tarjeta internacional ni rechazos por dólar tarjeta.</li>
            <li>✅ Soporte local si tenés dudas o problemas de acceso.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* CATÁLOGO POR PLATAFORMA */}
  <section class="max-w-4xl mx-auto pb-16 space-y-10">
    {platforms.map((plat) => (
      <div>
        <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2 mb-4">
          <span>{plat.emoji}</span>
          <span>{plat.brand}</span>
        </h2>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {plat.products.map((prod) => (
            <a
              href={`/cuentas-digitales/${prod.slug}`}
              class="group block rounded-2xl border border-slate-200 bg-white/95 px-5 py-5 hover:border-red-400 hover:shadow-md transition-all duration-150"
            >
              <span class={`inline-flex items-center rounded-full border text-[11px] px-2 py-0.5 mb-2 ${plat.tagColor}`}>
                {prod.tag}
              </span>
              <h3 class="text-sm font-semibold text-slate-900 group-hover:text-red-600 leading-snug">
                {prod.title}
              </h3>
              <p class="text-xs text-slate-600 mt-1">{prod.desc}</p>
              <p class="text-xs text-red-600 font-medium mt-3">Ver detalles →</p>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
